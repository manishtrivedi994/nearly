{
  "name": "local-feed-backend",
  "version": "1.0.0",
  "description": "AI-curated local news digest — backend API and worker",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp src/db/schema.sql dist/db/schema.sql",
    "start": "node dist/index.js",
    "worker": "node dist/worker/index.js",
    "dev": "ts-node src/index.ts",
    "test": "node --test tests/"
  },
  "dependencies": {
    "axios": "^1",
    "better-sqlite3": "^9",
    "cors": "^2",
    "express": "^4.18",
    "node-cron": "^3",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "rss-parser": "^3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7",
    "@types/cors": "^2",
    "@types/express": "^4",
    "@types/node": "^20",
    "@types/node-cron": "^3",
    "@types/nodemailer": "^8.0.0",
    "@types/web-push": "^3.6.4",
    "ts-node": "^10",
    "typescript": "^5"
  }
}
