# API Keys
NEWSAPI_KEY=              # newsapi.org free tier (100 req/day)
CEREBRAS_API_KEY=         # cloud.cerebras.ai — uses llama-3.3-70b

# Server
PORT=3001
ADMIN_PASSWORD=           # plain string, checked in admin route middleware

# Database
DB_PATH=./data/localfeed.db

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=         # base64url public key
VAPID_PRIVATE_KEY=        # base64url private key
VAPID_EMAIL=              # mailto: address sent in push requests

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:3001
VITE_VAPID_PUBLIC_KEY=    # must match VAPID_PUBLIC_KEY above
